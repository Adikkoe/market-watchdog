<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Panel - Market Watchdog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <h2 class="mb-4">Admin Panel</h2>

    <!-- Users -->
    <h4 class="mb-3">Users</h4>
    <div class="table-responsive mb-5">
      <table class="table table-striped table-bordered">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Registered</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((u, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><span class="badge bg-<%= u.role === 'ADMIN' ? 'danger' : 'primary' %>"><%= u.role %></span></td>
              <td><span class="badge bg-<%= u.isBlocked ? 'secondary' : 'success' %>"><%= u.isBlocked ? 'Blocked' : 'Active' %></span></td>
              <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
              <td>
                <% if (u.role !== 'ADMIN') { %>
                  <form method="POST" action="/admin/users/<%= u.id %>/toggle-block" style="display:inline;">
                    <button type="submit" class="btn btn-sm btn-<%= u.isBlocked ? 'success' : 'warning' %>">
                      <%= u.isBlocked ? 'Unblock' : 'Block' %>
                    </button>
                  </form>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Comparison History -->
    <h4 class="mb-3">Comparison History</h4>
    <div class="table-responsive mb-5">
      <table class="table table-sm table-bordered">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Company A</th>
            <th>Company B</th>
            <th>Summary</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (comparisons.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted">No comparisons yet.</td></tr>
          <% } else { %>
            <% comparisons.forEach((c, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><%= c.user.email %></td>
                <td><%= c.companyA.name %></td>
                <td><%= c.companyB.name %></td>
                <td><%= c.resultSummary %></td>
                <td><%= new Date(c.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Activity Logs -->
    <h4 class="mb-3">Activity Logs</h4>
    <div class="table-responsive">
      <table class="table table-sm table-bordered">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Action</th>
            <th>Details</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (activityLogs.length === 0) { %>
            <tr><td colspan="5" class="text-center text-muted">No activity logs yet.</td></tr>
          <% } else { %>
            <% activityLogs.forEach((log, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><%= log.user.email %></td>
                <td><%= log.action %></td>
                <td><%= log.details %></td>
                <td><%= new Date(log.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
