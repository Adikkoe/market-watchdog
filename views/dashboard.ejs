<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard - Market Watchdog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <h2 class="mb-4">Dashboard</h2>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card text-white bg-primary">
          <div class="card-body">
            <h6 class="card-title">Companies</h6>
            <h2 class="card-text"><%= totalCompanies %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-danger">
          <div class="card-body">
            <h6 class="card-title">Alerts</h6>
            <h2 class="card-text"><%= totalAlerts %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-success">
          <div class="card-body">
            <h6 class="card-title">Promotions</h6>
            <h2 class="card-text"><%= totalPromotions %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-info">
          <div class="card-body">
            <h6 class="card-title">Comparisons</h6>
            <h2 class="card-text"><%= totalComparisons %></h2>
          </div>
        </div>
      </div>
    </div>

    <h4 class="mb-3">Recent Alerts</h4>
    <div class="table-responsive">
      <table class="table table-striped table-bordered">
        <thead class="table-dark">
          <tr>
            <th>Company</th>
            <th>Type</th>
            <th>Message</th>
            <th>Severity</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentAlerts.length === 0) { %>
            <tr><td colspan="5" class="text-center text-muted">No alerts found.</td></tr>
          <% } else { %>
            <% recentAlerts.forEach(alert => { %>
              <tr>
                <td><a href="/companies/<%= alert.company.id %>"><%= alert.company.name %></a></td>
                <td><%= alert.type %></td>
                <td><%= alert.message %></td>
                <td>
                  <span class="badge bg-<%= alert.severity === 'HIGH' ? 'danger' : alert.severity === 'MEDIUM' ? 'warning' : 'secondary' %>">
                    <%= alert.severity %>
                  </span>
                </td>
                <td><%= new Date(alert.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
