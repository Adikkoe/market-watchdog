<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Compare Companies - Market Watchdog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <h2 class="mb-4">Compare Companies</h2>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="POST" action="/compare" class="row g-3 mb-4">
      <div class="col-md-5">
        <label class="form-label">Company A</label>
        <select name="companyAId" class="form-select" required>
          <option value="">Select Company A</option>
          <% companies.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %> (<%= c.industry %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-5">
        <label class="form-label">Company B</label>
        <select name="companyBId" class="form-select" required>
          <option value="">Select Company B</option>
          <% companies.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %> (<%= c.industry %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Compare</button>
      </div>
    </form>

    <% if (result) { %>
      <h4 class="mb-3">Comparison Results</h4>
      <p class="text-muted mb-3"><%= result.summary %></p>

      <div class="table-responsive">
        <table class="table table-bordered table-striped">
          <thead class="table-dark">
            <tr>
              <th>Metric</th>
              <th><%= result.companyA.name %></th>
              <th><%= result.companyB.name %></th>
              <th>Winner</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Monthly Revenue</td>
              <td>$<%= result.companyA.estimatedMonthlyRevenue.toLocaleString() %></td>
              <td>$<%= result.companyB.estimatedMonthlyRevenue.toLocaleString() %></td>
              <td>
                <% if (result.companyA.estimatedMonthlyRevenue > result.companyB.estimatedMonthlyRevenue) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.estimatedMonthlyRevenue > result.companyA.estimatedMonthlyRevenue) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td>Traffic Estimate</td>
              <td><%= result.companyA.trafficEstimate.toLocaleString() %></td>
              <td><%= result.companyB.trafficEstimate.toLocaleString() %></td>
              <td>
                <% if (result.companyA.trafficEstimate > result.companyB.trafficEstimate) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.trafficEstimate > result.companyA.trafficEstimate) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td>Growth Signal Score</td>
              <td><%= result.companyA.growthSignalScore.toFixed(1) %></td>
              <td><%= result.companyB.growthSignalScore.toFixed(1) %></td>
              <td>
                <% if (result.companyA.growthSignalScore > result.companyB.growthSignalScore) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.growthSignalScore > result.companyA.growthSignalScore) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td>Market Activity Score</td>
              <td><%= result.companyA.marketActivityScore.toFixed(1) %></td>
              <td><%= result.companyB.marketActivityScore.toFixed(1) %></td>
              <td>
                <% if (result.companyA.marketActivityScore > result.companyB.marketActivityScore) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.marketActivityScore > result.companyA.marketActivityScore) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td>Conversion Rate</td>
              <td><%= result.companyA.conversionRate.toFixed(2) %>%</td>
              <td><%= result.companyB.conversionRate.toFixed(2) %>%</td>
              <td>
                <% if (result.companyA.conversionRate > result.companyB.conversionRate) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.conversionRate > result.companyA.conversionRate) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td>Average Order Value</td>
              <td>$<%= result.companyA.averageOrderValue.toFixed(2) %></td>
              <td>$<%= result.companyB.averageOrderValue.toFixed(2) %></td>
              <td>
                <% if (result.companyA.averageOrderValue > result.companyB.averageOrderValue) { %>
                  <span class="badge bg-success"><%= result.companyA.name %></span>
                <% } else if (result.companyB.averageOrderValue > result.companyA.averageOrderValue) { %>
                  <span class="badge bg-success"><%= result.companyB.name %></span>
                <% } else { %>
                  <span class="badge bg-secondary">Tie</span>
                <% } %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</body>
</html>
